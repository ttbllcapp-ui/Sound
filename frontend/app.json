{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.dbmetertool.mp46q4",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Sound Pro uses the microphone to measure ambient noise levels in decibels while you're actively measuring."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.dbmetertool.mp46q4",
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      "expo-mail-composer",
      [
        "expo-audio",
        {
          "microphonePermission": "Sound Pro uses the microphone to measure ambient noise levels in decibels while you're actively measuring."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
